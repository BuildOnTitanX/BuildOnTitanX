---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import PageHeader from '@components/PageHeader.astro'
import { Card, Pagination } from 'accessible-astro-components'
import { getCollection } from 'astro:content'
import type { GetStaticPaths, Page } from 'astro'
import type { CollectionEntry } from 'astro:content'

export const getStaticPaths = (async ({ paginate }) => {
  const allPages = await getCollection('pages')
  const publishedPages = allPages.filter((page) => page.data.published !== false)

  return paginate(publishedPages, { pageSize: 6 })
}) satisfies GetStaticPaths

interface Props {
  page: Page<CollectionEntry<'pages'>>
}

const { page } = Astro.props
const currentPage = page.currentPage
const totalPages = Math.ceil(page.total / page.size)
---

<DefaultLayout title="All Pages">
  <PageHeader
    title="Block Pages"
    subtitle="Pages created with modular content blocks via PagesCMS."
    bgType="bordered"
  />

  <section class="my-12">
    <div class="container">
      <p class="text-sm italic">
        Page {currentPage} of {totalPages}
      </p>

      <ul class="my-3 grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
        {
          page.data.map((entry) => (
            <li>
              <Card url={`/${entry.slug}`} title={entry.data.title}>
                {entry.data.description ?? 'No description available.'}
              </Card>
            </li>
          ))
        }
      </ul>

      <div class="mt-12 grid place-content-center">
        <Pagination
          firstPage={page.url.prev ? '/pages' : null}
          previousPage={page.url.prev}
          nextPage={page.url.next}
          lastPage={page.url.next ? `/pages/${totalPages}` : null}
          currentPage={String(currentPage)}
          totalPages={String(totalPages)}
          ariaLabel="Page navigation"
        />
      </div>
    </div>
  </section>
</DefaultLayout>
