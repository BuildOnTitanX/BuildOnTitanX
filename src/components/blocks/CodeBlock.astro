---
import { Code } from 'astro:components'
const { language = 'javascript', children } = Astro.props

// Ensure code is properly formatted
const codeContent = children ? String(children).trim() : ''
---

<div class="my-8">
  <Code lang={language} wrap>
    {codeContent}
  </Code>
</div>

<style is:global>
  .astro-code {
    padding: 1rem;
    border-radius: 0.5rem;
    background: var(--code-bg) !important;
    color: var(--code-text) !important;
  }
  
  /* Ensure proper contrast in both themes */
  :root {
    --code-bg: #f6f8fa;
    --code-text: #24292e;
  }
  
  [data-theme="dark"] {
    --code-bg: #161b22;
    --code-text: #f0f6fc;
  }
</style>
