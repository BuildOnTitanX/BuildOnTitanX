---
import { Code } from 'astro:components'
const { language = 'javascript', children } = Astro.props

// Ensure code is properly formatted and handle undefined
const codeContent = children ? String(children).trim() : ''
---

<div class="my-8">
  {codeContent && (
    <Code lang={language} wrap>
      {codeContent}
    </Code>
  )}
</div>
